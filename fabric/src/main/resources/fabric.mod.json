{
  "schemaVersion": 1,
  "id": "wynnrunner",
  "version": "${version}",
  "name": "Wynnrunner",
  "description": "Extension mod for Wynntils to track more detailed lootrun data",
  "authors": [
    "Fis-chl"
  ],
  "contact": {
    "homepage": "https://github.com/Fis-chl"
  },
  "license": "LGPL-3.0",
  "icon": "assets/wynnrunner/logo.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "com.fischl.wynnrunner.fabric.WynnrunnerFabric"
    ]
  },
  "mixins": [
    "wynnrunner.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*",
    "wynntils": ">=$wynntils_version"
  },
  "suggests": {
    "another-mod": "*"
  }
}
